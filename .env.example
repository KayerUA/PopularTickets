# Публичный URL без завершающего слэша (обязателен для checkout / ссылок)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MVP без Przelewy24: true = после формы сразу «оплачено», билеты, письмо (если Resend).
# Когда подключите P24 — поставьте false и заполните P24_* ниже.
CHECKOUT_BYPASS_PAYMENT=true

# Контакт для покупателей (страница /pl/firma и т.д.)
NEXT_PUBLIC_CONTACT_EMAIL=

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Resend (письма с билетами; в bypass-режиме без Resend заказ всё равно paid, просто без email)
RESEND_API_KEY=
# Например: PopularTickets <tickets@ваш-домен> (домен должен быть верифицирован в Resend)
RESEND_FROM_EMAIL=

# Przelewy24 (когда CHECKOUT_BYPASS_PAYMENT=false)
P24_SANDBOX=true
P24_MERCHANT_ID=
P24_POS_ID=
P24_SECRET_ID=
P24_CRC_KEY=

# Админка
ADMIN_PASSWORD=
# Минимум 16 символов
ADMIN_JWT_SECRET=

# Check-in: если задан, требуется тот же секрет в UI при «Отметить вход»
CHECKIN_OPERATOR_TOKEN=
