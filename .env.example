# Публичный URL без завершающего слэша (canonical, Przelewy24 return/status, письма, sitemap).
# Локально: http://localhost:3000
# Vercel + свой домен: https://twoja-domena.pl (желательно явно в Production — один канонический URL).
# Если не задано: на production Vercel берётся VERCEL_PROJECT_PRODUCTION_URL (ваш домен после привязки в панели);
# иначе — https://$VERCEL_URL (*.vercel.app).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# MVP без Przelewy24: true = после формы сразу «оплачено», билеты, письмо (если Resend и не SKIP_ORDER_EMAIL).
# Когда подключите P24 — поставьте false и заполните P24_* ниже.
CHECKOUT_BYPASS_PAYMENT=true

# true = не отправлять письмо с билетами (билеты в БД всё равно создаются). Удобно для тестов на preview.
SKIP_ORDER_EMAIL=

# Контакт для покупателей (страница /pl/firma и т.д.)
NEXT_PUBLIC_CONTACT_EMAIL=

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# Альтернатива без префикса Next: SUPABASE_URL=https://xxxx.supabase.co

# Service role (секрет сервера; в Dashboard может называться «Secret» / sb_secret_…)
SUPABASE_SERVICE_ROLE_KEY=
# Алиас в некоторых шаблонах: SUPABASE_SECRET_KEY=

# Публикуемый ключ (Publishable / бывший anon, sb_publishable_…) — в этом MVP не используется в коде
# (все запросы к БД идут с сервера через service role). Можно оставить для совместимости с экспортом Supabase CLI.
# SUPABASE_PUBLISHABLE_KEY=

# Resend (письма с билетами; в bypass-режиме без Resend заказ всё равно paid, просто без email)
RESEND_API_KEY=
# Например: PopularTickets <tickets@ваш-домен> (домен должен быть верифицирован в Resend)
RESEND_FROM_EMAIL=

# Przelewy24 (когда CHECKOUT_BYPASS_PAYMENT=false)
P24_SANDBOX=true
P24_MERCHANT_ID=
P24_POS_ID=
P24_SECRET_ID=
P24_CRC_KEY=

# Админка
ADMIN_PASSWORD=
# Минимум 16 символов
ADMIN_JWT_SECRET=

# Подписанные ссылки на страницу «спасибо» / чек (рекомендуется в production).
# Если задан (≥16 символов), редиректы после оплаты используют ?rt=JWT вместо ?order=UUID;
# голый order в query для просмотра чека не принимается.
ORDER_RECEIPT_SECRET=

# Опционально: распределённый rate limit (serverless). Если не заданы — используется in-memory Map.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

