{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/telegram/retry",
      "schedule": "*/10 * * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "populartickets.pl" }],
      "destination": "https://www.populartickets.pl/:path*",
      "permanent": true
    }
  ]
}
